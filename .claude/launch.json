{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "backend",
      "runtimeExecutable": "cmd",
      "runtimeArgs": ["/c", "cd /d backend && set APP_MODE=monolith && python run.py"],
      "port": 8000
    },
    {
      "name": "frontend",
      "runtimeExecutable": "cmd",
      "runtimeArgs": ["/c", "cd /d frontend && npm run dev -- --host 127.0.0.1"],
      "port": 5173
    }
  ]
}
